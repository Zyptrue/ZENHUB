local DEFAULT_JUMPPOWER = 50

-- ==========================================
-- Konfigurasi Randomization
-- ==========================================
local CONFIG = {
    variationPercent = 0.10,     -- ±10% variasi dari base speed
    minInterval = 0.3,           -- Interval minimum update (detik)
    maxInterval = 0.8,           -- Interval maximum update (detik)
    useRandomization = true,     -- Toggle randomization on/off
}

local hooks = {
    walkspeed = DEFAULT_WALKSPEED,
    jumppower = DEFAULT_JUMPPOWER,
}

-- ==========================================
-- Hook Metamethod Setup
-- ==========================================
local old_index, old_newindex

old_index = hookmetamethod(game, "__index", function(self, property)
    if not checkcaller() and self:IsA("Humanoid") and self:IsDescendantOf(lp.Character) and hooks[property:lower()] then
        return hooks[property:lower()]
    end
    return old_index(self, property)
end)

old_newindex = hookmetamethod(game, "__newindex", function(self, property, value)
    if not checkcaller() and self:IsA("Humanoid") and self:IsDescendantOf(lp.Character) and hooks[property:lower()] then
        return
    end
    return old_newindex(self, property, value)
end)


-- ==========================================
-- Randomization System
-- ==========================================
local lastApplyTime = 0
local nextInterval = math.random(CONFIG.minInterval * 10, CONFIG.maxInterval * 10) / 10

local function getRandomizedSpeed()
    if not CONFIG.useRandomization then
        return currentWalkSpeedValue
    end
    
    -- Hitung variasi ±10% dari base speed
    local variation = currentWalkSpeedValue * CONFIG.variationPercent
    local minSpeed = currentWalkSpeedValue - variation
    local maxSpeed = currentWalkSpeedValue + variation
    
    -- Random speed dalam range (dengan 1 decimal agar tidak terlalu aneh)
    local randomSpeed = math.random(minSpeed * 10, maxSpeed * 10) / 10
    
    return randomSpeed
end


-- ==========================================
-- Fungsi Helper untuk Apply Nilai
-- ==========================================
local function applyWalkSpeed()
    local char = lp.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    
    if isWalkspeedEnabled then
        -- Toggle ON: apply randomization kalau speed di atas normal
        if currentWalkSpeedValue > DEFAULT_WALKSPEED then
            local finalSpeed = getRandomizedSpeed()
            hum.WalkSpeed = finalSpeed
            hooks.walkspeed = finalSpeed
        else
            hum.WalkSpeed = DEFAULT_WALKSPEED
            hooks.walkspeed = DEFAULT_WALKSPEED
        end
    else
        -- Toggle OFF: reset ke default
        hum.WalkSpeed = DEFAULT_WALKSPEED
        hooks.walkspeed = DEFAULT_WALKSPEED
    end
end

local function applyJumpPower()
    local char = lp.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    
    if isJumpPowerEnabled then
        hum.JumpPower = currentJumpPowerValue
        hum.UseJumpPower = true
        hooks.jumppower = currentJumpPowerValue
    else
        hum.JumpPower = DEFAULT_JUMPPOWER
        hum.UseJumpPower = true
        hooks.jumppower = DEFAULT_JUMPPOWER
    end
end


-- ==========================================
-- Randomization Loop
-- ==========================================
RunService.Heartbeat:Connect(function()
    -- Hanya jalan kalau toggle ON dan speed di atas normal
    if not isWalkspeedEnabled or currentWalkSpeedValue <= DEFAULT_WALKSPEED then
        return
    end
    
    local now = tick()
    if now - lastApplyTime >= nextInterval then
        applyWalkSpeed()
        lastApplyTime = now
        -- Interval berikutnya juga di-randomize (anti pattern!)
        nextInterval = math.random(CONFIG.minInterval * 10, CONFIG.maxInterval * 10) / 10
    end
end)


