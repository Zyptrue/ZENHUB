local function findFoodAnchor(item)
    -- 1. Cek apakah item itu Tool/Model dengan Handle
    if item:IsA("Tool") or item:IsA("Model") then
        -- Prioritas: Handle
        local handle = item:FindFirstChild("Handle")
        if handle and handle:IsA("BasePart") then
            return handle
        end
        
        -- Prioritas: Main (untuk Food)
        local main = item:FindFirstChild("Main")
        if main and main:IsA("BasePart") then
            return main
        end
        
        -- Prioritas: Model > BreadTop (untuk Subway)
        local model = item:FindFirstChild("Model")
        if model and model:IsA("Model") then
            local breadTop = model:FindFirstChild("BreadTop")
            if breadTop and breadTop:IsA("BasePart") then
                return breadTop
            end
        end
        
        -- Prioritas: BreadTop langsung
        local breadTop = item:FindFirstChild("BreadTop")
        if breadTop and breadTop:IsA("BasePart") then
            return breadTop
        end
        
        -- Fallback: PrimaryPart
        if item:IsA("Model") and item.PrimaryPart then
            return item.PrimaryPart
        end
        
        -- Fallback: BasePart pertama
        for _, child in ipairs(item:GetDescendants()) do
            if child:IsA("BasePart") then
                return child
            end
        end
    end
    
    -- 2. BasePart langsung
    if item:IsA("BasePart") then
        return item
    end
    
    return nil
end

