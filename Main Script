        ["Red"]      = Color3.fromRGB(255, 50, 50),
        ["Blue"]     = Color3.fromRGB(50, 100, 255),
        ["Green"]    = Color3.fromRGB(50, 255, 50),
        ["Yellow"]   = Color3.fromRGB(255, 255, 50),
