local function scanAllFood()
    local toolsFolder = Workspace:FindFirstChild("Tools")
    if not toolsFolder then return 0 end
    
    local count = 0
    for _, item in ipairs(toolsFolder:GetChildren()) do
        if isRegisteredFood(item) then
            createFoodESP(item)
            if foodESP[item] then count = count + 1 end
        end
    end
    
    print("[ESP] Scanning complete. Total food detected: " .. count)
    return count
end

-- ==========================================
-- Loop Update Jarak
-- ==========================================
local function startUpdateLoop()
    if updateConnection then updateConnection:Disconnect() end
    
    updateConnection = RunService.RenderStepped:Connect(function()
        local myChar = lp.Character
        local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end
        
        local toRemove = {}
        
        for food, data in pairs(foodESP) do
            local success = pcall(function()
                local anchor = data.anchor
                local distLabel = data.distLabel
                
                if not anchor or not anchor.Parent then
                    table.insert(toRemove, food)
                    return
                end
                
                local distance = (myHRP.Position - anchor.Position).Magnitude
                distLabel.Text = string.format("[%dm]", math.floor(distance))
                
                -- Warna jarak
                if distance < 10 then
                    distLabel.TextColor3 = Color3.fromRGB(255, 50, 50)   -- Merah (dekat)
                elseif distance < 30 then
                    distLabel.TextColor3 = Color3.fromRGB(255, 200, 0)   -- Kuning
                else
                    distLabel.TextColor3 = Color3.fromRGB(0, 255, 0)     -- Hijau (jauh)
                end
            end)
            
            if not success then
                table.insert(toRemove, food)
            end
        end
        
        for _, food in ipairs(toRemove) do
            removeFoodESP(food)
        end
    end)
end

-- ==========================================
-- Deteksi Food Baru / Food Hilang
-- ==========================================
local function setupFoodFolderListener()
    if listenerConnected then return end
    
    local toolsFolder = Workspace:FindFirstChild("Tools")
    if not toolsFolder then return end
    
    -- Food baru muncul
    toolsFolder.ChildAdded:Connect(function(child)
        if not espEnabled then return end
        if isRegisteredFood(child) then
            task.wait(0.2)
            createFoodESP(child)
        end
    end)
    
    -- Food hilang (diambil player)
    toolsFolder.ChildRemoved:Connect(function(child)
        if foodESP[child] then
            removeFoodESP(child)
        end
    end)
    
    listenerConnected = true
end

-- ==========================================
-- Toggle Food ESP ON/OFF
-- ==========================================
local function toggleFoodESP(state)
    espEnabled = state
    
    if state then
        local toolsFolder = Workspace:FindFirstChild("Tools")
        if not toolsFolder then
            toolsFolder = Workspace:WaitForChild("Tools", 15)
        end
        
        if toolsFolder then
            scanAllFood()
            setupFoodFolderListener()
            startUpdateLoop()
        end
    else
        if updateConnection then
            updateConnection:Disconnect()
            updateConnection = nil
        end
        clearAllFoodESP()
    end
end

-- ==========================================
-- UI Toggle (ESP Food)
-- ==========================================
local Toggle = Team:CreateToggle({
   Name = "ESP Food",
   CurrentValue = false,
   Flag = "ESPFoodToggle",
   Callback = function(Value)
       toggleFoodESP(Value)
   end,
})
