local function getTeamColor(player)
    local team = player.Team
    local teamName = team and team.Name or ""
    
    -- Mapping manual berdasarkan nama team (sesuaikan dengan game kamu)
    local teamColorMap = {
        -- Team dari script sebelumnya
        ["Fugitive"] = Color3.fromRGB(255, 50, 50),   -- Merah
        ["Prison"]   = Color3.fromRGB(255, 150, 0),   -- Orange
        ["Police"]   = Color3.fromRGB(0, 100, 255),   -- Biru
        ["Civilian"]    = Color3.fromRGB(50, 255, 50),   -- Hijau
        ["Hostage"]    = Color3.fromRGB(139, 0, 0),   -- Biru
        
