local function Equip(Name)
    if typeof(Name) == "string" then
        if Plr.Backpack:FindFirstChild(Name) then
            Plr.Backpack:FindFirstChild(Name).Parent = Plr.Character
        end
    elseif typeof(Name) == "Instance" and Name:IsA("Tool") then
        Name.Parent = Plr.Character
    end
end

local function Dupe(ToolName, ClickPart)
    for _, tool in next, Plr.Backpack:GetChildren() do
        if tool.Name == ToolName then
            Equip(tool)
        end
    end
    FireClick(ClickPart)
end

local function GetPlayersTeam()
    local TeamCheckedPlayers = {}
    for _, plr in pairs(game.Players:GetPlayers()) do
        if plr ~= Plr and plr.Team ~= Plr.Team then
            table.insert(TeamCheckedPlayers, plr)
        end
    end
    return TeamCheckedPlayers
end

local function GetUnBlockingPlayers(Check, Pos)
    local players = Check and GetPlayersTeam() or game.Players:GetPlayers()
    local LocalCharacter = Plr.Character
    local Players = {}
    for _, plr in pairs(players) do
        if plr ~= Plr and plr.Character and plr.Character:FindFirstChildOfClass("Humanoid") and plr.Character:FindFirstChildOfClass("Humanoid").Health ~= 0 then
            local Ray = Ray.new(Pos, (plr.Character.PrimaryPart.Position - Pos))
            local part = workspace:FindPartOnRayWithIgnoreList(Ray, {LocalCharacter})
            if part and part:IsDescendantOf(plr.Character) then
                table.insert(Players, plr)
            end
        end
    end
    return Players
end

local function getPlayer(String, Information)
    local Info = {
        ["Raycasting"] = false,
        ["Team"] = false,
        ["Position"] = Plr.Character.PrimaryPart.Position,
        ["Distance"] = math.huge
    }
    if Information then
        for name, value in pairs(Information) do
            if Info[name] ~= nil then Info[name] = value end
        end
    end

    local players
    if Info["Raycasting"] and Info["Team"] then
        players = GetUnBlockingPlayers(true, Info["Position"])
    elseif Info["Raycasting"] and not Info["Team"] then
        players = GetUnBlockingPlayers(false, Info["Position"])
    elseif Info["Team"] and not Info["Raycasting"] then
        players = GetPlayersTeam()
    else
        players = game.Players:GetPlayers()
    end

    local Found = {}
    local strl = String:lower()
    if strl == "all" then
        for i,v in pairs(players) do pcall(function()
            if (Plr.Character.PrimaryPart.Position - v.Character.PrimaryPart.Position).magnitude <= Info["Distance"] then table.insert(Found, v) end
        end) end
    elseif strl == "others" then
        for i,v in pairs(players) do pcall(function()
            if v ~= Plr and (Plr.Character.PrimaryPart.Position - v.Character.PrimaryPart.Position).magnitude <= Info["Distance"] then table.insert(Found, v) end
        end) end
    elseif strl == "nearest" then
        local closestPlayer, closestDistance
        for _, p in pairs(players) do
            if p ~= Plr and p.Character and p.Character:FindFirstChildOfClass("Humanoid") and p.Character:FindFirstChildOfClass("Humanoid").Health ~= 0 then
                local distance = (Plr.Character.PrimaryPart.Position - p.Character.PrimaryPart.Position).Magnitude
                if not closestDistance or distance < closestDistance then
                    closestDistance = distance
                    closestPlayer = p
                end
            end
        end
        if closestPlayer then table.insert(Found, closestPlayer) end
    end
    return Found
end

