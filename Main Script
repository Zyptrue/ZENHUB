        ["White"]    = Color3.fromRGB(255, 255, 255),
        ["Black"]    = Color3.fromRGB(50, 50, 50),
    }
    
    -- Cek apakah nama team ada di mapping (case-insensitive)
    for name, color in pairs(teamColorMap) do
        if string.lower(teamName) == string.lower(name) then
